# Django settings
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database settings
# If using SQLite: sqlite:///db.sqlite3
# If using PostgreSQL: postgres://user:password@localhost:5402/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Gemini API Settings
GEMINI_API_KEY=your-gemini-api-key-here
